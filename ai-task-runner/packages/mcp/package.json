  },
  "keywords": [
    "ai",
    "task",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Innate Team",
  "license": "MIT",
  "dependencies": {
    "@innate/ai-task-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
