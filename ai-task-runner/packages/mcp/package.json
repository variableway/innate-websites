{
  "name": "@innate/ai-task-mcp",
  "version": "1.0.0",
  "description": "AI Task Runner - MCP Server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ai-task-mcp": "./bin/mcp-server.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/server.ts --format cjs --dts",
    "dev": "tsup src/server.ts --format cjs --dts --watch",
