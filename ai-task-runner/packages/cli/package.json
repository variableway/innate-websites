{
  "name": "@innate/ai-task-cli",
  "version": "1.0.0",
  "description": "AI Task Runner - CLI Tool",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "task": "./bin/task.js",
    "ai-task": "./bin/task.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "task",
    "cli",
    "github",
    "automation"
  ],
  "author": "Innate Team",
  "license": "MIT",
  "dependencies": {
    "@innate/ai-task-core": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
